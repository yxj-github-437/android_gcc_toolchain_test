From b1b70e7db03e2f6cff7b7bbf253b7cac5bc18cf8 Mon Sep 17 00:00:00 2001
From: yxj-github-437 <2457369732@qq.com>
Date: Thu, 7 May 2026 01:20:02 +0800
Subject: [PATCH] add flag -nostdinc++ for libstdc++ build

---
 libstdc++-v3/src/c++11/Makefile.am | 2 +-
 libstdc++-v3/src/c++11/Makefile.in | 2 +-
 libstdc++-v3/src/c++20/Makefile.am | 2 +-
 libstdc++-v3/src/c++20/Makefile.in | 2 +-
 libstdc++-v3/src/c++23/Makefile.am | 2 +-
 libstdc++-v3/src/c++23/Makefile.in | 2 +-
 libstdc++-v3/src/c++26/Makefile.am | 2 +-
 libstdc++-v3/src/c++26/Makefile.in | 2 +-
 libstdc++-v3/src/c++98/Makefile.am | 2 +-
 libstdc++-v3/src/c++98/Makefile.in | 2 +-
 10 files changed, 10 insertions(+), 10 deletions(-)

diff --git a/libstdc++-v3/src/c++11/Makefile.am b/libstdc++-v3/src/c++11/Makefile.am
index d29efacdcda..4174dd1ea0e 100644
--- a/libstdc++-v3/src/c++11/Makefile.am
+++ b/libstdc++-v3/src/c++11/Makefile.am
@@ -206,7 +206,7 @@ endif
 # OPTIMIZE_CXXFLAGS on the compile line so that -O2 can be overridden
 # as the occasion calls for it.
 AM_CXXFLAGS = \
-	-std=gnu++11 \
+	-std=gnu++11 -nostdinc++ \
 	$(glibcxx_lt_pic_flag) $(glibcxx_compiler_shared_flag) \
 	$(XTEMPLATE_FLAGS) $(VTV_CXXFLAGS) \
 	$(WARN_CXXFLAGS) $(OPTIMIZE_CXXFLAGS) $(CONFIG_CXXFLAGS)
